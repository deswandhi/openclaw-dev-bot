{
  "$schema": "https://docs.openclaw.ai/schemas/openclaw.schema.json",
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "bea9722261743c3fcd2d540fe75a302827f842550a73d0f0"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "plugins": {
    "allow": [
      "codex",
      "telegram",
      "qwen"
    ],
    "entries": {
      "codex": {
        "enabled": true,
        "config": {
          "discovery": {
            "enabled": true,
            "timeoutMs": 2500
          },
          "appServer": {
            "transport": "stdio",
            "command": "codex",
            "args": [
              "app-server",
              "--listen",
              "stdio://"
            ],
            "requestTimeoutMs": 60000,
            "approvalPolicy": "on-request",
            "sandbox": "workspace-write"
          },
          "computerUse": {
            "enabled": false,
            "autoInstall": false,
            "marketplaceDiscoveryTimeoutMs": 60000,
            "pluginName": "computer-use",
            "mcpServerName": "computer-use"
          }
        }
      },
      "qwen": {
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "qwen": {
        "baseUrl": "${QWEN_BASE_URL}",
        "apiKey": "${QWEN_API_KEY}",
        "auth": "api-key",
        "api": "openai-completions",
        "timeoutSeconds": 60,
        "models": [
          {
            "id": "${QWEN_MODEL}",
            "name": "Alibaba Qwen Primary",
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "qwen/${QWEN_MODEL}"
    },
    "list": [
      {
        "id": "yuna",
        "name": "${OPENCLAW_AGENT_NAME}",
        "default": true,
        "model": "qwen/${QWEN_MODEL}",
        "systemPromptOverride": "You are Yuna, an OpenClaw assistant for a Data & AI Product Expert at Indosat. Your tone is calm, thoughtful, supportive, professional, concise, and reliable. Help with proposal drafting, meeting preparation, technical architecture, cloud, GPU and data platform analysis, reminders, productivity, vendor and partner analysis, executive summaries, and decision support. Prefer structured, actionable answers. Separate facts, assumptions, risks, and recommendations. Protect confidential Indosat, customer, partner, pricing, credential, and strategy information. Never reveal API keys, Telegram tokens, private keys, auth files, WhatsApp session credentials, or other secrets. Ask concise clarifying questions only when needed to avoid a material mistake."
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupPolicy": "allowlist",
      "textChunkLimit": 3900
    },
    "whatsapp": {
      "enabled": false,
      "dmPolicy": "pairing",
      "allowFrom": [],
      "textChunkLimit": 4000,
      "chunkMode": "length",
      "mediaMaxMb": 50,
      "sendReadReceipts": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupPolicy": "allowlist",
      "groupAllowFrom": [],
      "accounts": {
        "work": {}
      },
      "defaultAccount": "work"
    }
  },
  "web": {
    "enabled": true,
    "heartbeatSeconds": 60,
    "whatsapp": {
      "keepAliveIntervalMs": 25000,
      "connectTimeoutMs": 60000,
      "defaultQueryTimeoutMs": 60000
    },
    "reconnect": {
      "initialMs": 2000,
      "maxMs": 120000,
      "factor": 1.4,
      "jitter": 0.2,
      "maxAttempts": 0
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.5.7",
    "lastTouchedAt": "2026-05-11T08:35:52.340Z"
  }
}
